<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
<title>DMC Fire Apparatus — Percent Calculator</title>
<style>
  :root{
    --bg:#080808;
    --panel:#131313;
    --panel-2:#191919;
    --line:#2a2a2a;
    --red:#d81f28;
    --red-bright:#ff2130;
    --red-dim:#7a1219;
    --white:#f4f4f4;
    --muted:#8a8a8a;
    --font: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  }
  *{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent;}
  html,body{background:var(--bg);}
  body{
    font-family:var(--font);
    color:var(--white);
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:flex-start;
    padding:26px 16px 60px;
  }
  .app{width:100%;max-width:440px;}

  /* ---- Header / logo ---- */
  .logo-wrap{text-align:center;margin-bottom:22px;}
  .logo-wrap img{
    width:170px;height:170px;object-fit:cover;
    border-radius:14px;
    display:inline-block;
  }
  .rule{
    height:3px;width:100%;
    background:linear-gradient(90deg,transparent,var(--red) 15%,var(--red-bright) 50%,var(--red) 85%,transparent);
    box-shadow:0 0 14px 1px rgba(255,33,48,.55);
    margin:18px 0 24px;
    border-radius:2px;
  }

  /* ---- Amount input ---- */
  .field-label{
    font-size:11px;letter-spacing:.22em;text-transform:uppercase;
    color:var(--muted);font-weight:700;margin-bottom:9px;display:block;
  }
  .amount-box{
    position:relative;display:flex;align-items:center;
    background:var(--panel);
    border:1px solid var(--line);
    border-radius:12px;
    padding:0 16px;
    transition:border-color .15s ease, box-shadow .15s ease;
  }
  .amount-box:focus-within{
    border-color:var(--red);
    box-shadow:0 0 0 3px rgba(216,31,40,.18);
  }
  .amount-box .dollar{
    font-size:34px;font-weight:800;color:var(--red-bright);margin-right:6px;line-height:1;
  }
  #amount{
    flex:1;background:transparent;border:0;outline:0;
    color:var(--white);
    font-size:38px;font-weight:800;
    padding:16px 0;width:100%;
    letter-spacing:-.01em;
  }
  #amount::placeholder{color:#3a3a3a;}

  /* ---- Results ---- */
  .results{margin-top:22px;display:flex;flex-direction:column;gap:10px;}
  .row{
    display:flex;align-items:center;gap:14px;
    background:var(--panel);
    border:1px solid var(--line);
    border-left:3px solid var(--red);
    border-radius:10px;
    padding:15px 16px;
    cursor:pointer;
    transition:background .12s ease, transform .05s ease, opacity .12s ease, border-color .12s ease;
    user-select:none;
  }
  .row:active{transform:scale(.99);}
  .row:hover{background:var(--panel-2);}
  /* unselected state */
  .row.off{opacity:.42;border-left-color:var(--line);}

  .check{
    flex:0 0 auto;
    width:24px;height:24px;border-radius:6px;
    border:2px solid var(--red);
    background:var(--red);
    display:flex;align-items:center;justify-content:center;
    color:#fff;font-size:15px;font-weight:900;line-height:1;
    transition:background .12s ease, border-color .12s ease;
  }
  .row.off .check{background:transparent;border-color:#444;}
  .row.off .check .tick{display:none;}

  .row .pct{
    font-size:19px;font-weight:800;color:var(--white);
    flex:1;
  }
  .row .val{
    font-size:24px;font-weight:800;color:var(--red-bright);
    font-variant-numeric:tabular-nums;letter-spacing:-.01em;
  }
  .row.off .val{color:var(--muted);}

  /* ---- Copy button ---- */
  .copy-btn{
    width:100%;margin-top:20px;
    background:var(--red);
    color:#fff;
    border:0;border-radius:12px;
    padding:18px;
    font-size:15px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;
    cursor:pointer;
    transition:background .15s ease, transform .05s ease;
    box-shadow:0 6px 20px rgba(216,31,40,.28);
  }
  .copy-btn:hover{background:var(--red-bright);}
  .copy-btn:active{transform:translateY(1px);}
  .copy-btn.done{background:#1a7a34;box-shadow:0 6px 20px rgba(26,122,52,.3);}
  .copy-btn.warn{background:#333;box-shadow:none;}

  .hint{
    text-align:center;color:#555;font-size:11px;margin-top:14px;letter-spacing:.03em;
  }

  /* ---- Toast ---- */
  .toast{
    position:fixed;left:50%;bottom:26px;transform:translateX(-50%) translateY(20px);
    background:#111;border:1px solid var(--red);
    color:#fff;font-size:13px;font-weight:600;
    padding:12px 20px;border-radius:10px;
    opacity:0;pointer-events:none;
    transition:opacity .2s ease, transform .2s ease;
    box-shadow:0 8px 30px rgba(0,0,0,.6);
    z-index:50;
  }
  .toast.show{opacity:1;transform:translateX(-50%) translateY(0);}
</style>
</head>
<body>
  <div class="app">
    <div class="logo-wrap">
      <img src="data:image/jpeg;base64," alt="DMC Fire Apparatus">
    </div>
    <div class="rule"></div>

    <label class="field-label" for="amount">Enter amount</label>
    <div class="amount-box">
      <span class="dollar">$</span>
      <input id="amount" type="text" inputmode="decimal" placeholder="0.00" autocomplete="off">
    </div>

    <div class="results" id="results">
      <div class="row" data-pct="2.5">
        <span class="check"><span class="tick">&#10003;</span></span>
        <span class="pct">2.5%</span>
        <span class="val" data-out>$0.00</span>
      </div>
      <div class="row" data-pct="5">
        <span class="check"><span class="tick">&#10003;</span></span>
        <span class="pct">5%</span>
        <span class="val" data-out>$0.00</span>
      </div>
      <div class="row" data-pct="7">
        <span class="check"><span class="tick">&#10003;</span></span>
        <span class="pct">7%</span>
        <span class="val" data-out>$0.00</span>
      </div>
      <div class="row" data-pct="10">
        <span class="check"><span class="tick">&#10003;</span></span>
        <span class="pct">10%</span>
        <span class="val" data-out>$0.00</span>
      </div>
    </div>

    <button class="copy-btn" id="copyAll">Copy Selected</button>
    <p class="hint">Tap a row to include or remove it from the copy</p>
  </div>

  <div class="toast" id="toast">Copied</div>

<script>
  var amountEl = document.getElementById('amount');
  var rows = Array.prototype.slice.call(document.querySelectorAll('.row'));
  var toast = document.getElementById('toast');
  var copyAllBtn = document.getElementById('copyAll');
  var toastTimer, btnTimer;

  function money(n){
    return '$' + n.toLocaleString('en-US',{minimumFractionDigits:2, maximumFractionDigits:2});
  }

  // ---- Live comma formatting in the amount field ----
  function formatAmountInput(){
    var raw = amountEl.value.replace(/[^0-9.]/g,'');
    // collapse extra dots -> keep only the first
    var firstDot = raw.indexOf('.');
    if(firstDot !== -1){
      raw = raw.slice(0, firstDot + 1) + raw.slice(firstDot + 1).replace(/\./g,'');
    }
    var hasDot = raw.indexOf('.') !== -1;
    var intPart = hasDot ? raw.slice(0, raw.indexOf('.')) : raw;
    var decPart = hasDot ? raw.slice(raw.indexOf('.') + 1, raw.indexOf('.') + 3) : '';
    // strip leading zeros but keep a single 0 before a decimal
    intPart = intPart.replace(/^0+(?=\d)/,'');
    var withCommas = intPart === '' ? '' : Number(intPart).toLocaleString('en-US');
    var out = withCommas;
    if(hasDot) out = (withCommas === '' ? '0' : withCommas) + '.' + decPart;
    amountEl.value = out;
  }
  function parseAmount(){
    var v = parseFloat(amountEl.value.replace(/,/g,''));
    return isNaN(v) ? 0 : v;
  }
  function calc(){
    var amt = parseAmount();
    rows.forEach(function(row){
      var pct = parseFloat(row.getAttribute('data-pct'));
      row.querySelector('[data-out]').textContent = money(amt * pct / 100);
    });
  }
  amountEl.addEventListener('input', function(){
    formatAmountInput();
    calc();
  });

  function showToast(msg){
    toast.textContent = msg;
    toast.classList.add('show');
    clearTimeout(toastTimer);
    toastTimer = setTimeout(function(){ toast.classList.remove('show'); }, 1600);
  }

  // Reliable copy with fallback for iframes / older browsers
  function copyText(text){
    if(navigator.clipboard && window.isSecureContext){
      navigator.clipboard.writeText(text).then(function(){}, function(){ fallbackCopy(text); });
    } else {
      fallbackCopy(text);
    }
  }
  function fallbackCopy(text){
    var ta = document.createElement('textarea');
    ta.value = text;
    ta.style.position='fixed'; ta.style.top='-9999px';
    document.body.appendChild(ta);
    ta.focus(); ta.select();
    try{ document.execCommand('copy'); }catch(e){}
    document.body.removeChild(ta);
  }

  // ---- Row selection (multi-select) ----
  rows.forEach(function(row){
    row.addEventListener('click', function(){
      row.classList.toggle('off');
    });
  });

  // ---- Copy selected rows ----
  copyAllBtn.addEventListener('click', function(){
    var selected = rows.filter(function(r){ return !r.classList.contains('off'); });
    if(selected.length === 0){
      showToast('Select at least one row');
      copyAllBtn.classList.add('warn');
      copyAllBtn.textContent = 'Nothing selected';
      clearTimeout(btnTimer);
      btnTimer = setTimeout(function(){
        copyAllBtn.classList.remove('warn');
        copyAllBtn.textContent = 'Copy Selected';
      }, 1600);
      return;
    }
    var amt = parseAmount();
    var lines = [];
    lines.push('DMC Fire Apparatus');
    lines.push('Amount: ' + money(amt));
    lines.push('');
    selected.forEach(function(row){
      var pct = row.getAttribute('data-pct');
      var val = row.querySelector('[data-out]').textContent;
      lines.push(pct + '%  =  ' + val);
    });
    copyText(lines.join('\n'));
    showToast(selected.length + (selected.length === 1 ? ' row copied' : ' rows copied'));
    copyAllBtn.classList.add('done');
    copyAllBtn.textContent = 'Copied \u2713';
    clearTimeout(btnTimer);
    btnTimer = setTimeout(function(){
      copyAllBtn.classList.remove('done');
      copyAllBtn.textContent = 'Copy Selected';
    }, 1600);
  });

  calc();
  amountEl.focus();
</script>
</body>
</html>
